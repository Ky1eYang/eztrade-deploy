# ----------------------------------------
# Compose profiles
# ----------------------------------------
# Use local postgres/redis containers:
#   COMPOSE_PROFILES=local-infra
# Use external postgres/redis (host or remote):
#   COMPOSE_PROFILES=
COMPOSE_PROFILES=local-infra

# ----------------------------------------
# Common
# ----------------------------------------
TZ=Asia/Shanghai
ALL_PROXY=
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=

# ----------------------------------------
# Images
# ----------------------------------------
STAR_DASHBOARD_IMAGE=ky1eyang/star-dashboard:latest
STAR_PLATFORM_IMAGE=ky1eyang/star-platform:latest
EZTRADE_SERVER_IMAGE=ky1eyang/eztrade-server:latest
POSTGRES_IMAGE=postgres:16-alpine
REDIS_IMAGE=redis:7-alpine

# ----------------------------------------
# Local postgres/redis service settings (when COMPOSE_PROFILES=local-infra)
# ----------------------------------------
POSTGRES_PORT=5432
POSTGRES_USER=midplatform
POSTGRES_PASSWORD=replace_me_postgres_password
POSTGRES_DB=midplatform

REDIS_PORT=6379
REDIS_PASSWORD=default

# ----------------------------------------
# star-platform
# ----------------------------------------
STAR_PLATFORM_PORT=7800
STAR_PLATFORM_WORKERS=4
STAR_PLATFORM_APP_NAME=midplatform
STAR_PLATFORM_REDIS_URL=redis://default:default@redis:6379/0
STAR_PLATFORM_DATABASE_URL=postgresql+psycopg://midplatform:replace_me_postgres_password@postgres:5432/midplatform
STAR_PLATFORM_SPYDER_TASKS=okx_web3,jupiter,polymarket
RQDATAC_LICENSE_KEY=replace_me_rqdatas_license_key
STAR_PLATFORM_JUPITER_API_KEY=replace_me_jupiter_api_key

# ----------------------------------------
# eztrade-server
# ----------------------------------------
EZTRADE_PORT=7878
EZTRADE_CONFIG_FILE=/config/cfg.toml
EZTRADE_LOG_LEVEL=info

OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_SERVICE_NAME=ez-trade
OTEL_SERVICE_VERSION=0.3.x

OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=
BINANCE_API_KEY=
BINANCE_SECRET_KEY=
EZTRADE_JUPITER_API_KEY=
SOLANA_PUBLIC_KEY=
SOLANA_PRIVATE_KEY=

# ----------------------------------------
# star-dashboard
# ----------------------------------------
STAR_DASHBOARD_PORT=3000
NODE_ENV=production
PM2_ENV=production
PM2_INSTANCES=1
NODE_TLS_REJECT_UNAUTHORIZED=0

DASHBOARD_REDIS_HOST=redis
DASHBOARD_REDIS_PORT=6379
DASHBOARD_REDIS_USERNAME=default
DASHBOARD_REDIS_PASSWORD=default
DASHBOARD_REDIS_DIR=midplatform
DASHBOARD_REDIS_SANDBOX_ROOT=eztrade

DASHBOARD_PY_BACKEND_URL=http://star-platform:7800
DASHBOARD_SANDBOX_BACKEND_URL=http://eztrade-server:7878
DASHBOARD_TRADE_DB_URL=postgres://midplatform:replace_me_postgres_password@postgres:5432/midplatform

# ----------------------------------------
# External infra quick example
# ----------------------------------------
# COMPOSE_PROFILES=
# STAR_PLATFORM_REDIS_URL=redis://default:your_password@192.168.1.10:6379/0
# STAR_PLATFORM_DATABASE_URL=postgresql+psycopg://user:password@192.168.1.20:5432/dbname
# DASHBOARD_REDIS_HOST=192.168.1.10
# DASHBOARD_REDIS_PORT=6379
# DASHBOARD_REDIS_USERNAME=default
# DASHBOARD_REDIS_PASSWORD=your_password
# DASHBOARD_TRADE_DB_URL=postgres://user:password@192.168.1.20:5432/dbname
